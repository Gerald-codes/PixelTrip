# PixelTrip environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Supabase ---
# Project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Anon/public key (safe to expose to the browser; used for Realtime presence + broadcast)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key (SERVER ONLY — bypasses row-level security, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- kiro / AWS Bedrock ---
# All AI agent calls are server-side only. These credentials must never reach the browser.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# Bedrock model identifier used for agent invocations
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
